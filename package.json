{
  "name": "srcc",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "rm-image-metadata": "find src \\( -name '*.jpg' -o -name '*.jpeg' -o -name '*.png' -o -name '*.gif' \\) -exec exiftool -all= -tagsfromfile @ -Orientation -overwrite_original {} \\;"
  },
  "pre-commit": [
    "rm-image-metadata"
  ],
  "overrides": {
    "vite": "^7"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.2",
    "@astrojs/vercel": "^10.0.3",
    "@tailwindcss/typography": "^0.5.10",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "astro": "^6.1.1",
    "astro-icon": "^1.1.5",
    "@iconify-json/maki": "^1.2.4",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/tabler": "^1.2.33",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "pre-commit": "^1.2.2",
    "prettier": "^3.1.1",
    "prettier-plugin-astro": "^0.12.3",
    "prettier-plugin-tailwindcss": "^0.5.10"
  }
}
